# OpenAI API key for the AI schema assistant chat feature.
# Copy this file to .env.local and fill in your key.
#
# ⚠  SECURITY WARNING:
# VITE_ prefixed variables are embedded in the client bundle and visible to
# anyone who inspects the built output. Use a key with strict usage/spend limits.
# For production, replace the Vite dev proxy with a server-side proxy that
# holds this key and is not exposed to the browser.
#
# The Vite dev server proxies /api/openai → https://api.openai.com
# so the browser never sends the key directly during development.
VITE_OPENAI_API_KEY=your-api-key-here
